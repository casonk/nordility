@startuml classes_nordility
set namespaceSeparator none
class "ActionOutcome" as src.nordility.web.ActionOutcome {
  repair
  result
}
class "<color:red>CommandExecutionError</color>" as src.nordility.client.CommandExecutionError {
}
class "CommandResult" as src.nordility.client.CommandResult {
  command : tuple[str, ...]
  group : str | None
  message : str
  returncode : int | None
  stderr : str
  stdout : str
}
class "<color:red>ConfigurationError</color>" as src.nordility.client.ConfigurationError {
}
class "NordVPNClient" as src.nordility.client.NordVPNClient {
  backend : str
  executable
  change(speed: str, group: str | None, wait_seconds: float | None, auto_login: bool, keepass_entry: str | None, keepass_profile: str | None, restore_wireguard: bool, wireguard_fwmark: int) -> CommandResult
  connect(group: str | None, wait_seconds: float, auto_login: bool, keepass_entry: str | None, keepass_profile: str | None) -> CommandResult
  disconnect(wait_seconds: float) -> CommandResult
  list_groups(speed: str) -> tuple[str, ...]
  login(token: str | None, keepass_entry: str | None, keepass_profile: str | None) -> CommandResult
  pick_group(speed: str) -> str
}
class "<color:red>NordilityError</color>" as src.nordility.client.NordilityError {
}
class "NordilityWebController" as src.nordility.web.NordilityWebController {
  client
  perform_action(payload: dict[str, Any]) -> ActionOutcome
  status() -> dict[str, Any]
}
class "NordilityWebHandler" as src.nordility.web.make_handler.NordilityWebHandler {
  server_version : str
  do_GET() -> None
  do_HEAD() -> None
  do_POST() -> None
  log_message(fmt: str) -> None
}
class "WireGuardRestoreSummary" as src.nordility.client.WireGuardRestoreSummary {
  interfaces : tuple[str, ...]
  refreshed : tuple[str, ...]
  routing_candidates : tuple[str, ...]
  routing_restored : tuple[str, ...]
  started : tuple[str, ...]
  describe() -> str
  message_suffix() -> str
}
src.nordility.client.CommandExecutionError --|> src.nordility.client.NordilityError
src.nordility.client.ConfigurationError --|> src.nordility.client.NordilityError
src.nordility.web.ActionOutcome --> src.nordility.client.CommandResult : result
src.nordility.web.ActionOutcome --> src.nordility.client.WireGuardRestoreSummary : repair
src.nordility.client.NordVPNClient --* src.nordility.web.NordilityWebController : client
@enduml
